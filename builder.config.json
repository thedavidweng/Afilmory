{
  "repo": {
    "enable": true,
    "url": "https://github.com/thedavidweng/gallery-assets"
  },
  "storage": {
    "provider": "github",
    "owner": "thedavidweng",
    "repo": "gallery-assets",
    "branch": "main",
    "path": "photos",
    "useRawUrl": true
  },
  "options": {
    "concurrency": {
      "maxWorkers": 2,
      "workerConcurrency": 1,
      "requestDelay": 1000
    },
    "logging": {
      "level": "info",
      "format": "text"
    },
    "performance": {
      "cache": true,
      "cacheTTL": 3600,
      "retryCount": 3,
      "retryDelay": 2000
    }
  },
  "logging": {
    "verbose": true,
    "level": "info",
    "outputToFile": false
  },
  "performance": {
    "worker": {
      "workerCount": 8,
      "timeout": 30000,
      "useClusterMode": true,
      "workerConcurrency": 2
    }
  }
}