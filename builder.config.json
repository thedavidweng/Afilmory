{
  "repo": {
    "enable": true,
    "url": "https://github.com/thedavidweng/gallery-assets"
  },
  "storage": {
    "provider": "github",
    "owner": "thedavidweng",
    "repo": "gallery-assets",
    "branch": "main",
    "path": "photos",
    "useRawUrl": true
  },
  "options": {
    "defaultConcurrency": 8,
    "enableLivePhotoDetection": true,
    "showProgress": true,
    "showDetailedStats": true
  },
  "logging": {
    "verbose": true,
    "level": "info",
    "outputToFile": false
  },
  "performance": {
    "worker": {
      "workerCount": 8,
      "timeout": 30000,
      "useClusterMode": true,
      "workerConcurrency": 2
    }
  }
}